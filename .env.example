# ============================================================
# AmieLife Backend — Environment Variables Template
# Copy this file and rename to .env (for local tooling only)
# For production: set these directly in your platform dashboard
# See docs/secrets-configuration.md for full instructions
# ============================================================

ASPNETCORE_ENVIRONMENT=Development

# Database — replace with your Supabase connection string
ConnectionStrings__DefaultConnection=Host=db.YOURREF.supabase.co;Database=postgres;Username=postgres;Password=YOURPASSWORD;Port=5432;SSL Mode=Require;Trust Server Certificate=true

# JWT — generate with: openssl rand -base64 64
Jwt__Secret=REPLACE_WITH_64_CHAR_RANDOM_SECRET
Jwt__Issuer=AmieLife
Jwt__Audience=AmieLife-Users
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=14

# CORS — your frontend URL
Cors__AllowedOrigins__0=http://localhost:3000

# App base URL — used in email links
App__BaseUrl=http://localhost:3000
